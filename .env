# ── robotmk-starter ──────────────────────────────────────────────────────────
# RCC environment  
RMKS_ENVIRONMENT=rf-full
# Devcontainer type  
RMKS_DEVCONTAINER=cmk25

# ── Environment ───────────────────────────────────────────────────────────────
# VNC desktop resolution (default: 1280x1024 if not set)
# VNC_RESOLUTION=1920x1080
RMKCRYPTPW=rmksecret
ROBOTMK_HEADLESS_HOST=true